<head>
  <style>
    body { width: 60%; }
    .bold { font-weight: bold; }
    .dataTable { font-family: sans-serif; border-collapse: collapse; font-size: 8pt; margin-top: 20px; }
    .dataTable tr:nth-child(even) { background-color: #f2f2f2; }
    .dataTable tbody tr:hover * { background-color: rgb(194, 149, 141) !important; }
    .dataTable th { background-color: #4CAF50; color: white; }
    .dataTable td { white-space: nowrap; }
    .bga { background-color: #dce9d5; }
    .learned { background-color: lightgreen; }
    .played { background-color: lightblue; }
    .banned { background-color: #f0a0a0; }
    .pill {
      padding: 4px 8px;
      margin-left: 8px;
      border-radius: 16px;
    }
    .highlight { background-color: yellow; }
    .number { text-align: right; }
    .bad { background-color: silver; }
    #games { max-height: 70vh; overflow-y: auto; } /* keep body rows scrollable */
    #games thead th {
      position: sticky;   /* let header stick while you scroll */
      top: 0;             /* pin to the top of the scroll area */
      z-index: 2;         /* sit above body rows & hover colors */
    }
  </style>

  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <link href="https://cdn.datatables.net/2.3.2/css/dataTables.dataTables.min.css" rel="stylesheet">
  <script src="https://cdn.datatables.net/2.3.2/js/dataTables.min.js"></script>
  <script>
    $(function() {
      $('#games').DataTable({
        order: [[3, 'desc']],
        paging: false
      });
    });
  </script>
</head>
<body>
  <table id="games">
    <thead>
      <tr>
        <th>Year</th>
        <th>Game</th>
        <th>Group</th>
        <th>Weight</th>
        <th>Votes</th>
        <th>Votes Rank</th>
        <th>Votes Per Year</th>
        <th>Votes Per Year Rank</th>
        <th>Rank</th>
        <th>Rating</th>
        <th>Player Count</th>
        <th>Playtime</th>
        <th>Price</th>
        <th>Stores</th>
        <th>B2GO Price</th>
        <th>Subdomain</th>
        <th>Category</th>
      </tr>
    </thead>
    <tbody>
      <% @games.each do |game| %>
        <%
          bad_conditions = {
            bad_player_count: !(1..2).cover?(game.player_count.min),
            bad_playtime: !(1...60).cover?(game.max_playtime),
            bad_rank: !(1...500).cover?(game.rank),
            bad_rating: !(7..).cover?(game.rating&.round(1)),
            bad_price: !(1..30).cover?(game.price),
            bad_b2go_price: !(1..13).cover?(game.b2go_price),
            bad_rating_count: !(1...500).cover?(game.rating_count_rank),
            bad_rating_count_rank: !(1...500).cover?(game.rating_count_rank),
            bad_votes_per_year: !(1...500).cover?(game.votes_per_year_rank),
            bad_votes_per_year_rank: !(1...500).cover?(game.votes_per_year_rank),
            bad_weight: !(1...3).cover?(game.weight&.round(1)),
            bad_year: !(...Time.now.year - 5).cover?(game.year),
          }
        %>
        <tr>
          <td class="number <%= 'bad' if bad_conditions[:bad_year] %>"><%= int(game.year) %></td>
          <td>
            <a href="https://boardgamegeek.com<%= game.href %>"><%= game.name %></a>
            <% if game.learned? %><span class="pill learned">L</span><% end %>
            <% if game.played? %><span class="pill played">P</span><% end %>
            <% if game.banned? %><span class="pill banned">B</span><% end %>
          </td>
          <td><%= game.group %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_weight] %>"><%= float(game.weight) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_rating_count] %>"><%= int(game.rating_count) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_rating_count_rank] %>"><%= int(game.rating_count_rank) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_votes_per_year] %>"><%= int(game.votes_per_year) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_votes_per_year_rank] %>"><%= int(game.votes_per_year_rank) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_rank] %>"><%= int(game.rank) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_rating] %>"><%= float(game.rating) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_player_count] %>"><%= game.player_count.unknown? ? "" : game.player_count %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_playtime] %>"><%= int(game.max_playtime) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_price] %>"><%= int(game.price) %></td>
          <td><%= store_links(game) %></td>
          <td class="number <%= 'bad' if bad_conditions[:bad_b2go_price] %>"><%= int(game.b2go_price) %></td>
          <td><%= game.subdomains %></td>
          <td class="<%= 'bga' if game.bga? %>"><%= game.category_label %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</body>
