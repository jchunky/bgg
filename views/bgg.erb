<head>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/list.js/2.3.1/list.min.js"></script>
  <style>
    body { max-width: 95%; margin: 0; padding-left: 20px; }
    .bold { font-weight: bold; }
    table { font-family: sans-serif; border-collapse: collapse; font-size: 8pt; margin-top: 10px; width: auto; }
    table tr:nth-child(even) { background-color: #f2f2f2; }
    table tbody tr:hover * { background-color: rgb(194, 149, 141) !important; }
    table th { background-color: #4CAF50; color: white; text-align: left; padding: 4px 8px; }
    table td { white-space: nowrap; padding: 2px 8px; }
    th.sort { cursor: pointer; user-select: none; }
    th.sort::after { content: ' ⇕'; font-size: 7pt; opacity: 0.5; }
    th.sort.asc::after { content: ' ↑'; opacity: 1; }
    th.sort.desc::after { content: ' ↓'; opacity: 1; }
    .bga { background-color: #dce9d5; }
    .learned { background-color: lightgreen; }
    .played { background-color: lightblue; }
    .banned { background-color: #f0a0a0; }
    .pill {
      padding: 4px 8px;
      margin-left: 8px;
      border-radius: 16px;
    }
    .highlight { background-color: yellow; }
    .number { text-align: right; }
    .bad, .bad a { color: silver; }
    #games { max-height: 70vh; overflow-y: auto; } /* keep body rows scrollable */
    h2 { font-family: Arial; margin: 0; display: inline; }
    .table-header { margin-top: 16px; display: flex; align-items: baseline; gap: 12px; }
    input.search { font-size: 9pt; padding: 4px 8px; border: 1px solid #ccc; border-radius: 4px; width: 200px; }
    #games thead th {
      position: sticky;   /* let header stick while you scroll */
      top: 0;             /* pin to the top of the scroll area */
      z-index: 2;         /* sit above body rows & hover colors */
    }
  </style>
</head>
<body>
  <div id="games-list">
    <div class="table-header">
      <h2>Games (<%= @games.size %>)</h2>
      <input class="search" placeholder="Search...">
    </div>
    <table id="games">
      <thead>
        <tr>
          <th class="sort" data-sort="year">Year</th>
          <th class="sort" data-sort="game-name">Game</th>
          <th class="sort" data-sort="group">Group</th>
          <th class="sort" data-sort="weight">Weight</th>
          <th class="sort" data-sort="votes">Votes</th>
          <th class="sort" data-sort="votes-rank">Votes Rank</th>
          <th class="sort" data-sort="votes-per-year">Votes Per Year</th>
          <th class="sort" data-sort="votes-per-year-rank">Votes Per Year Rank</th>
          <th class="sort" data-sort="rank">Rank</th>
          <th class="sort" data-sort="rating">Rating</th>
          <th class="sort" data-sort="player-count">Player Count</th>
          <th class="sort" data-sort="playtime">Playtime</th>
          <th class="sort" data-sort="price">Price</th>
          <th class="sort" data-sort="b2go-price">B2GO Price</th>
          <th class="sort" data-sort="subdomain">Subdomain</th>
          <th class="sort" data-sort="category">Category</th>
        </tr>
      </thead>
      <tbody class="list">
        <% @games.each do |game| %>
          <%
            bad_conditions = {
              bad_player_count: !(1..2).cover?(game.player_count.min),
              bad_playtime: !(1...60).cover?(game.max_playtime),
              bad_rank: !(1...500).cover?(game.rank),
              bad_rating: !(7..).cover?(game.rating&.round(1)),
              bad_price: !(1..30).cover?(game.price),
              bad_b2go_price: !(1..13).cover?(game.b2go_price),
              bad_rating_count: !(1...500).cover?(game.rating_count_rank),
              bad_rating_count_rank: !(1...500).cover?(game.rating_count_rank),
              bad_votes_per_year: !(1...500).cover?(game.votes_per_year_rank),
              bad_votes_per_year_rank: !(1...500).cover?(game.votes_per_year_rank),
              bad_weight: !(1...3).cover?(game.weight&.round(1)),
              bad_year: !(...Time.now.year - 5).cover?(game.year),
            }
          %>
          <tr>
            <td class="number year <%= 'bad' if bad_conditions[:bad_year] %>"><%= int(game.year) %></td>
            <td>
              <a href="https://boardgamegeek.com<%= game.href %>"><span class="game-name"><%= game.name %></span></a>
              <% if game.learned? %><span class="pill learned">L</span><% end %>
              <% if game.played? %><span class="pill played">P</span><% end %>
              <% if game.banned? %><span class="pill banned">B</span><% end %>
            </td>
            <td class="group"><%= game.group %></td>
            <td class="number weight <%= 'bad' if bad_conditions[:bad_weight] %>"><%= float(game.weight) %></td>
            <td class="number votes <%= 'bad' if bad_conditions[:bad_rating_count] %>"><%= int(game.rating_count) %></td>
            <td class="number votes-rank <%= 'bad' if bad_conditions[:bad_rating_count_rank] %>"><%= int(game.rating_count_rank) %></td>
            <td class="number votes-per-year <%= 'bad' if bad_conditions[:bad_votes_per_year] %>"><%= int(game.votes_per_year) %></td>
            <td class="number votes-per-year-rank <%= 'bad' if bad_conditions[:bad_votes_per_year_rank] %>"><%= int(game.votes_per_year_rank) %></td>
            <td class="number rank <%= 'bad' if bad_conditions[:bad_rank] %>"><%= int(game.rank) %></td>
            <td class="number rating <%= 'bad' if bad_conditions[:bad_rating] %>"><%= float(game.rating) %></td>
            <td class="number player-count <%= 'bad' if bad_conditions[:bad_player_count] %>"><%= game.player_count.unknown? ? "" : game.player_count %></td>
            <td class="number playtime <%= 'bad' if bad_conditions[:bad_playtime] %>"><%= int(game.max_playtime) %></td>
            <td class="number <%= 'bad' if bad_conditions[:bad_price] %>"><% if game.bgp_url %><a href="<%= game.bgp_url %>"><span class="price"><%= int(game.price) %></span></a><% else %><span class="price"><%= int(game.price) %></span><% end %></td>
            <td class="number <%= 'bad' if bad_conditions[:bad_b2go_price] %>"><% if game.b2go_url %><a href="<%= game.b2go_url %>"><span class="b2go-price"><%= int(game.b2go_price) %></span></a><% else %><span class="b2go-price"><%= int(game.b2go_price) %></span><% end %></td>
            <td class="subdomain"><%= game.subdomains %></td>
            <td class="category <%= 'bga' if game.bga? %>"><%= game.category_label %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <script>
    var gamesList = new List('games-list', {
      valueNames: ['year', 'game-name', 'group', 'weight', 'votes', 'votes-rank', 'votes-per-year', 'votes-per-year-rank', 'rank', 'rating', 'player-count', 'playtime', 'price', 'b2go-price', 'subdomain', 'category']
    });
    gamesList.sort('weight', { order: 'desc' });
  </script>
</body>
